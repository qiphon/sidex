{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SideX",
  "version": "0.1.2",
  "identifier": "com.siden.sidex",
  "build": {
    "frontendDist": "../sidex-ui",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "SideX",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true,
        "visible": true,
        "dragDropEnabled": false,
        "useHttpsScheme": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "/tmp/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVENkM0QkJDNjlBRjQ0OTcKUldTWFJLOXB2RXRzN1UrM3V3WFlNSFpBb0xRQ25yRjdydHIxc2YyZWZPU0o1MHpUU0lIY0FOVUYK",
      "endpoints": [
        "https://cdn.siden.ai/releases/sidex/latest/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright \u00a9 2026 Siden Technologies Inc. All rights reserved.",
    "category": "DeveloperTool",
    "shortDescription": "A fast, open-source code editor.",
    "longDescription": "SideX is a fast, lightweight, open-source code editor built for developers.",
    "resources": [
      "extension-host/*",
      "shell-integration/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: kima Booker (D983H3RN86)",
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ]
      }
    }
  }
}
