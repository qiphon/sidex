# =============================================================================
# SideX .gitignore
# =============================================================================

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Build output ─────────────────────────────────────────────────────────────
dist/
out/
build/
*.tsbuildinfo

# ── Rust / Cargo ─────────────────────────────────────────────────────────────
**/target/

# ── WASM build artifacts (wasm-pack output) ──────────────────────────────────
**/pkg/

# ── Extensions (auto-installed on first dev/build via npm run setup) ──────────
/extensions/

# ── Cargo.lock for library crates ───────────────────────────────────────────
# Library lock files should not be committed (Cargo best practice).
# The application lock (src-tauri/Cargo.lock) IS committed.
sidex-extension-sdk/Cargo.lock
extensions-rust/Cargo.lock
examples/**/Cargo.lock

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
._*
Thumbs.db
Desktop.ini
ehthumbs.db

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── Local dev tooling (Cargo overrides, Claude Code state) ───────────────────
.cargo/
.claude/

# ── Environment / Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
/docs

# ── Tauri generated ──────────────────────────────────────────────────────────
src-tauri/gen/

# ── Test / Coverage ──────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── Misc ─────────────────────────────────────────────────────────────────────
*.tgz
*.vsix
.turbo/
.cache/
.parcel-cache/

# ── Incomplete Rust WASM extensions (stubs, not yet LSP-backed) ──────────────
extensions-rust/debug-auto-launch-extension/
extensions-rust/debug-server-ready-extension/
extensions-rust/emmet-extension/
extensions-rust/git-extension/
extensions-rust/grunt-extension/
extensions-rust/gulp-extension/
extensions-rust/html-language-extension/
extensions-rust/jake-extension/
extensions-rust/json-language-extension/
extensions-rust/markdown-extension/
extensions-rust/merge-conflict-extension/
extensions-rust/npm-extension/
extensions-rust/php-language-extension/
extensions-rust/references-view-extension/
extensions-rust/terminal-suggest-extension/

# ── Cloudflare Wrangler (marketplace-proxy dev state) ────────────────────────
infrastructure/marketplace-proxy/.wrangler/
infrastructure/marketplace-proxy/node_modules/


extensions-rust/css-language-extension/css-data.json
extensions-rust/css-language-extension/css-builtin.json
extensions-rust/css-language-extension/src/css_data.rs
extensions-meta.json
public/builtin-extensions.js
